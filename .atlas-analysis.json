  "keyFeatures": [
    "Role-based authentication (admin/vendor) via Firebase Auth",
    "Vendor dashboard with daily orders and monthly sales metrics",
    "Product management with Bsale sync and desync capabilities",
    "Order management with status filtering and modal details",
    "Sent orders tracking for fulfilled deliveries",
    "Admin panel for managing vendors and platform-wide products",
    "Bsale OAuth integration for Chilean billing platform",
    "Shopify product and inventory synchronization",
    "MercadoPago payment processing with webhook support",
    "Uber Direct delivery quoting and tracking"
  ],
  "publicApiSurface": [
    "GET /shopify/products",
    "POST /shopify/inventory",
    "GET /shopify/orders",
    "GET /bsale/products",
    "POST /bsale/oauth",
    "GET /bsale/sucursales",
    "POST /sync/products",
    "POST /sync/desync",
    "GET /sync/marketplace-products",
    "POST /mp/create-pay",
    "GET /mp/cart",
