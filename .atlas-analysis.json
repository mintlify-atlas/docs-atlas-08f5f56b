{
  "projectType": "saas",
  "projectName": "Masca Dashboard",
  "projectDescription": "A full-stack SaaS vendor management dashboard built with Vue 3 and Firebase, enabling vendors to manage products, track orders, and integrate with Bsale, Shopify, MercadoPago, and Uber Direct.",
  "theme": "mint",
  "primaryColor": "#43bb83",
  "lightColor": "#3c8b74",
  "darkColor": "#344d5c",
